@{
    Layout = null;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    bool IsActive(string a) =>
        string.Equals(currentAction, a, StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DTI Laguna OneLink</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <!-- Hanken Grotesk + Inter (body/UI) -->
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;600;700;800&family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
    <!-- Anton (DTI brand word) -->
    <link href="https://fonts.googleapis.com/css2?family=Anton&display=swap" rel="stylesheet">
    <!-- Open Sauce Sans (OneLink brand word) -->
    <link href="https://api.fontshare.com/v2/css?f[]=open-sauce-sans@400,500,600,700&display=swap" rel="stylesheet">
    <!-- Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet">

    <link rel="stylesheet" href="~/css/adminlayout.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- ══════════════ TOPBAR ══════════════ -->
    <header class="topbar">
        <div class="topbar-left">
            <div class="topbar-search">
                <span class="material-symbols-outlined search-icon">search</span>
                <input type="text" placeholder="Search tasks or records..." />
            </div>
        </div>

        <div class="topbar-right">
            <!-- Notification bell -->
            <button class="notif-btn" id="notifBtn" aria-label="Notifications">
                <span class="material-symbols-outlined">notifications</span>
                <span class="notif-dot" id="notifDot"></span>
            </button>

            <div class="topbar-divider"></div>

            <!-- User info + avatar + chevron badge -->
            <div class="topbar-user" id="profileTrigger">
                <div class="user-info">
                    <span class="user-name">EMPLOYEE</span>
                    <span class="user-role">Staff</span>
                </div>
                <div class="avatar-wrapper">
                    <div class="user-avatar">
                        <img src="~/images/employee.jpg"
                             alt="Employee photo"
                             onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                        <span class="avatar-fallback material-symbols-outlined">person</span>
                    </div>
                    <span class="material-symbols-outlined profile-chevron">expand_more</span>
                </div>
            </div>

            <!-- Profile dropdown -->
            <div class="profile-dropdown" id="profileDropdown">
                <div class="profile-dropdown-header">
                    <div class="user-avatar user-avatar-lg">
                        <img src="~/images/employee.jpg"
                             alt="Employee photo"
                             onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                        <span class="avatar-fallback material-symbols-outlined">person</span>
                    </div>
                    <div>
                        <div class="profile-dd-name">EMPLOYEE</div>
                        <div class="profile-dd-role">Staff</div>
                    </div>
                </div>
                <div class="profile-dropdown-divider"></div>
                <form asp-controller="Account" asp-action="Logout" method="post" style="margin:4px;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="profile-logout-btn">
                        <span class="material-symbols-outlined">logout</span>
                        <span>Sign Out</span>
                    </button>
                </form>
            </div>
        </div>
    </header>

    <!-- ══════════════ SIDEBAR ══════════════ -->
    <aside class="sidebar">

        <!-- Brand block: logo + DTI (Anton) + OneLink (Open Sauce) -->
        <div class="sidebar-brand">
            <img src="~/images/dti-logo.png"
                 alt="DTI Laguna Provincial Office"
                 class="sidebar-logo" />
            <div class="brand-text">
                <span class="brand-dti">DTI  Laguna</span>
                <span class="brand-onelink">
                <span class="word-one">One</span><span class="word-link">Link</span>
                </span>
            </div>
        </div>

        <nav class="sidebar-nav">

            <a asp-controller="Employee" asp-action="Index"
               class="nav-item @(IsActive("Index") ? "active" : "")">
                <span class="material-symbols-outlined"
                      style="@(IsActive("Index") ? "font-variation-settings:'FILL' 1;" : "")">dashboard</span>
                <span>Dashboard</span>
            </a>

            <a asp-controller="Employee" asp-action="TaskManagement"
               class="nav-item @(IsActive("TaskManagement") ? "active" : "")">
                <span class="material-symbols-outlined">assignment</span>
                <span>Task Management</span>
            </a>

            <a asp-controller="Employee" asp-action="Reports"
               class="nav-item @(IsActive("Reports") ? "active" : "")">
                <span class="material-symbols-outlined">assessment</span>
                <span>Reports</span>
            </a>

        </nav>
    </aside>

    <!-- ══════════════ MAIN CONTENT ══════════════ -->
    <main class="main-content">
        @RenderBody()
    </main>

    <script src="~/js/adminlayout.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
