@model DTIOneLink.Models.TaskItem
@{
    Layout = "~/Views/Admin/AdminLayout.cshtml";
    ViewData["Title"] = "Create Task";
}

@section Styles {
    <link rel="stylesheet" href="~/css/tasks-index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tasks-create.css" asp-append-version="true" />
}

<!-- ── Validation Summary ────────────────────────────── -->
@if (!ViewData.ModelState.IsValid)
{
    <div class="validation-summary">
        <span class="material-symbols-outlined">error</span>
        <div asp-validation-summary="All" class="validation-errors"></div>
    </div>
}

<!-- ── Dimmed background (Task Management list) ───────── -->
<div class="task-bg">

    <!-- Page header (dimmed) -->
    <div class="page-header">
        <div class="page-header-text">
            <h2 class="page-title">Task Management</h2>
            <p class="page-sub">Assign, track, and manage departmental workflows.</p>
        </div>
        <div class="page-actions">
            <a class="btn-primary-pill">
                <span class="material-symbols-outlined">add</span>
                CREATE TASK
            </a>
            <button class="btn-outline-pill">
                <span class="material-symbols-outlined">filter_list</span>
                FILTER
            </button>
        </div>
    </div>

    <!-- Empty table card (dimmed) -->
    <div class="glass-card">
        <div class="card-toolbar">
            <div class="search-wrap">
                <span class="material-symbols-outlined search-icon">search</span>
                <input type="text" class="search-input"
                       placeholder="Search tasks, assignees, or employee names..." />
            </div>
            <div class="toolbar-filters">
                <div class="filter-chip">
                    <span>Status: All</span>
                    <span class="material-symbols-outlined chip-icon">expand_more</span>
                </div>
                <div class="filter-chip">
                    <span>Sort: Newest</span>
                    <span class="material-symbols-outlined chip-icon">sort</span>
                </div>
            </div>
        </div>
        <div class="table-scroll">
            <table class="task-table">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Task Assignee</th>
                        <th>Due Date</th>
                        <th>Task Progress</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="7" class="empty-state">
                            <div class="empty-state-content">
                                <span class="material-symbols-outlined empty-icon">assignment</span>
                                <p class="empty-text">No tasks yet</p>
                                <p class="empty-sub">Create a task to get started.</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div class="pagination-bar">
            <span class="pagination-info">No tasks to display</span>
            <div class="pagination-btns">
                <button class="page-btn page-nav">
                    <span class="material-symbols-outlined">chevron_left</span>
                </button>
                <button class="page-btn page-active">1</button>
                <button class="page-btn page-nav">
                    <span class="material-symbols-outlined">chevron_right</span>
                </button>
            </div>
        </div>
    </div>

</div>

<!-- ── Create Task Modal ───────────────────────────────── -->
<div class="modal-overlay" id="createTaskModal">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modalTitle">

        <!-- Header -->
        <div class="modal-header">
            <div>
                <h2 class="modal-title" id="modalTitle">Create New Task</h2>
                <p class="modal-sub">Assign a new operational task to a team member.</p>
            </div>
            <a asp-controller="Tasks" asp-action="Index" class="modal-close" aria-label="Close">
                <span class="material-symbols-outlined">close</span>
            </a>
        </div>

        <!-- Body -->
        <div class="modal-body">
            <form id="taskForm" asp-controller="Tasks" asp-action="Create" method="post" novalidate>
                @Html.AntiForgeryToken()

                <!-- Task Name -->
                <div class="field-group">
                    <label class="field-label" for="taskName">TASK NAME <span class="required-star">*</span></label>
                    <input class="pill-input" id="taskName" asp-for="TaskName" type="text"
                           placeholder="e.g. MSME Development Seminar Coordination" />
                    <span asp-validation-for="TaskName" class="field-error"></span>
                </div>

                <!-- Assignee + Due Date -->
                <div class="field-row">
                    <div class="field-group">
                        <label class="field-label" for="assignee">ASSIGNEE <span class="required-star">*</span></label>
                        <div class="select-wrap">
                            <input class="pill-input" id="assignee" asp-for="Assignee" type="text"
                                   placeholder="Enter assignee name" />
                            <span class="material-symbols-outlined select-icon">person</span>
                        </div>
                        <span asp-validation-for="Assignee" class="field-error"></span>
                    </div>
                    <div class="field-group">
                        <label class="field-label" for="dueDate">DUE DATE <span class="required-star">*</span></label>
                        <div class="select-wrap">
                            <input class="pill-input" id="dueDate" asp-for="DueDate" type="date" />
                            <span class="material-symbols-outlined select-icon">calendar_today</span>
                        </div>
                        <span asp-validation-for="DueDate" class="field-error"></span>
                    </div>
                </div>

                <!-- Priority -->
                <div class="field-group">
                    <span class="field-label">PRIORITY LEVEL <span class="required-star">*</span></span>
                    <div class="priority-row">
                        <label class="priority-option">
                            <input type="radio" asp-for="Priority" value="low" />
                            <div class="priority-pill">
                                <span class="priority-dot dot-low"></span>
                                <span>Low</span>
                            </div>
                        </label>
                        <label class="priority-option">
                            <input type="radio" asp-for="Priority" value="medium" checked />
                            <div class="priority-pill">
                                <span class="priority-dot dot-medium"></span>
                                <span>Medium</span>
                            </div>
                        </label>
                        <label class="priority-option">
                            <input type="radio" asp-for="Priority" value="high" />
                            <div class="priority-pill">
                                <span class="priority-dot dot-high"></span>
                                <span>High</span>
                            </div>
                        </label>
                    </div>
                    <span asp-validation-for="Priority" class="field-error"></span>
                </div>

                <!-- Description -->
                <div class="field-group">
                    <label class="field-label" for="description">TASK DESCRIPTION <span class="required-star">*</span></label>
                    <textarea class="pill-input" id="description" asp-for="Description" rows="4"
                              placeholder="Describe the task scope, objectives, and any specific requirements..."></textarea>
                    <span asp-validation-for="Description" class="field-error"></span>
                </div>

            </form>
        </div>

        <!-- Footer -->
        <div class="modal-footer">
            <a asp-controller="Tasks" asp-action="Index" class="btn-cancel">Cancel</a>
            <button class="btn-create" id="createBtn" type="submit" form="taskForm">
                <span class="material-symbols-outlined"
                      style="font-variation-settings:'FILL' 1; font-size:20px;">add</span>
                Create Task
            </button>
        </div>

    </div>
</div>

@section Scripts {
    <script src="~/js/tasks-create.js" asp-append-version="true"></script>
}
