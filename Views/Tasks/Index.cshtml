@model DTIOneLink.ViewModels.TaskManagementViewModel
@{
    Layout = "~/Views/Admin/AdminLayout.cshtml";
    ViewData["Title"] = "Task Management";
    var tasks = Model.Tasks;
}

@section Styles {
    <link rel="stylesheet" href="~/css/tasks-index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tasks-create.css" asp-append-version="true" />
}

<!-- ── Success Banner ─────────────────────────────────── -->
@if (TempData["SuccessMessage"] is string successMsg)
{
    <div class="success-banner" id="successBanner">
        <span class="material-symbols-outlined">check_circle</span>
        <span>@successMsg</span>
        <button class="success-close" onclick="this.parentElement.remove()" type="button" aria-label="Dismiss">
            <span class="material-symbols-outlined">close</span>
        </button>
    </div>
}

<!-- ── Page Header ─────────────────────────────────────── -->
<div class="page-header">
    <div class="page-header-text">
    </div>
    <div class="page-actions">
        <button type="button" id="openCreateTask" class="btn-primary-pill">
            <span class="material-symbols-outlined">add</span>
            CREATE TASK
        </button>
        <button class="btn-outline-pill">
            <span class="material-symbols-outlined">filter_list</span>
            FILTER
        </button>
    </div>
</div>

<!-- ── Task List Card ──────────────────────────────────── -->
<div class="glass-card">

    <!-- Toolbar -->
    <div class="card-toolbar">
        <div class="search-wrap">
            <span class="material-symbols-outlined search-icon">search</span>
            <input type="text" class="search-input"
                   placeholder="Search tasks, assignees, or employee names..." />
        </div>
        <div class="toolbar-filters">
            <div class="filter-chip">
                <span>Status: All</span>
                <span class="material-symbols-outlined chip-icon">expand_more</span>
            </div>
            <div class="filter-chip">
                <span>Sort: Newest</span>
                <span class="material-symbols-outlined chip-icon">sort</span>
            </div>
        </div>
    </div>

    <!-- Table -->
    <div class="table-scroll">
        <table class="task-table">
            <thead>
                <tr>
                    <th>Employee</th>
                    <th>Task Assignee</th>
                    <th>Due Date</th>
                    <th>Task Progress</th>
                    <th>Priority</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (tasks != null && tasks.Any())
                {
                    foreach (var task in tasks)
                    {
                        var initials = task.Assignee.Length > 0
                            ? string.Concat(task.Assignee.Split(' ').Where(w => w.Length > 0).Take(2).Select(w => char.ToUpper(w[0])))
                            : "?";
                        var progressWidth = task.Progress;
                        var priorityBadgeClass = task.Priority?.ToLower() switch
                        {
                            "high" => "badge-high",
                            "medium" => "badge-medium",
                            "low" => "badge-low",
                            _ => "badge-medium"
                        };
                        var statusBadgeClass = task.Status?.ToLower() switch
                        {
                            "in progress" or "progress" => "status-progress",
                            "completed" or "complete" => "status-complete",
                            _ => "status-pending"
                        };
                        var progressBarClass = progressWidth >= 80 ? "progress-green" : "";
                        <tr class="task-row">
                            <td class="td-first">
                                <div class="employee-cell">
                                    <div class="emp-avatar">@initials</div>
                                    <div>
                                        <div class="emp-name">@task.Assignee</div>
                                        <div class="emp-role">Assignee</div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="td-muted">@task.TaskName</span></td>
                            <td><span class="td-date">@task.DueDate.ToString("MMM dd, yyyy")</span></td>
                            <td>
                                <div class="progress-cell">
                                    <div class="progress-track">
                                        <div class="progress-fill @progressBarClass" style="width: @progressWidth%;"></div>
                                    </div>
                                    <span class="progress-pct">@progressWidth%</span>
                                </div>
                            </td>
                            <td>
                                <span class="badge @priorityBadgeClass">@task.Priority</span>
                            </td>
                            <td>
                                <span class="status-badge @statusBadgeClass">@task.Status</span>
                            </td>
                            <td class="td-last">
                                <button class="more-btn" aria-label="More options"
                                        onclick="event.stopPropagation(); alert('Task details: @task.TaskName')">
                                    <span class="material-symbols-outlined">more_horiz</span>
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="empty-state">
                            <div class="empty-state-content">
                                <span class="material-symbols-outlined empty-icon">assignment</span>
                                <p class="empty-text">No tasks yet</p>
                                <p class="empty-sub">Create a task to get started.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="pagination-bar">
        <span class="pagination-info">
            @if (tasks != null && tasks.Any())
            {
                @:Showing @tasks.Count() task@(tasks.Count() != 1 ? "s" : "")
            }
            else
            {
                @:No tasks to display
            }
        </span>
        <div class="pagination-btns">
            <button class="page-btn page-nav">
                <span class="material-symbols-outlined">chevron_left</span>
            </button>
            <button class="page-btn page-active">1</button>
            <button class="page-btn page-nav">
                <span class="material-symbols-outlined">chevron_right</span>
            </button>
        </div>
    </div>
</div>

<!-- ── Create Task Modal (overlay, in-place) ───────────── -->
<div class="modal-overlay @(Model.OpenModal ? "" : "is-hidden")" id="createTaskModal">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modalTitle">

        <!-- Header -->
        <div class="modal-header">
            <div>
                <h2 class="modal-title" id="modalTitle">Create New Task</h2>
                <p class="modal-sub">Assign a new operational task to a team member.</p>
            </div>
            <button type="button" class="modal-close" data-close-modal aria-label="Close">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <!-- Body -->
        <div class="modal-body">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="validation-summary">
                    <span class="material-symbols-outlined">error</span>
                    <div asp-validation-summary="All" class="validation-errors"></div>
                </div>
            }

            <form id="taskForm" asp-controller="Tasks" asp-action="Create" method="post" novalidate>
                @Html.AntiForgeryToken()

                <!-- Task Name -->
                <div class="field-group">
                    <label class="field-label" for="taskName">TASK NAME <span class="required-star">*</span></label>
                    <input class="pill-input" id="taskName" asp-for="NewTask.TaskName" type="text"
                           placeholder="e.g. MSME Development Seminar Coordination" />
                    <span asp-validation-for="NewTask.TaskName" class="field-error"></span>
                </div>

                <!-- Assignee + Due Date -->
                <div class="field-row">
                    <div class="field-group">
                        <label class="field-label" for="assignee">ASSIGNEE <span class="required-star">*</span></label>
                        <div class="select-wrap">
                            <select class="pill-input" id="assignee" asp-for="NewTask.Assignee">
                                <option value="">Select assignee</option>
                                @foreach (var u in Model.Users)
                                {
                                    <option value="@u.FullName">@u.FullName</option>
                                }
                            </select>
                            <span class="material-symbols-outlined select-icon">person</span>
                        </div>
                        @if (!Model.Users.Any())
                        {
                            <span class="field-hint">No users yet — add accounts in User Management first.</span>
                        }
                        <span asp-validation-for="NewTask.Assignee" class="field-error"></span>
                    </div>
                    <div class="field-group">
                        <label class="field-label" for="dueDate">DUE DATE <span class="required-star">*</span></label>
                        <div class="select-wrap">
                            <input class="pill-input" id="dueDate" asp-for="NewTask.DueDate" type="date" />
                            <span class="material-symbols-outlined select-icon">calendar_today</span>
                        </div>
                        <span asp-validation-for="NewTask.DueDate" class="field-error"></span>
                    </div>
                </div>

                <!-- Priority -->
                <div class="field-group">
                    <span class="field-label">PRIORITY LEVEL <span class="required-star">*</span></span>
                    <div class="priority-row">
                        <label class="priority-option">
                            <input type="radio" asp-for="NewTask.Priority" value="low" />
                            <div class="priority-pill">
                                <span class="priority-dot dot-low"></span>
                                <span>Low</span>
                            </div>
                        </label>
                        <label class="priority-option">
                            <input type="radio" asp-for="NewTask.Priority" value="medium" checked />
                            <div class="priority-pill">
                                <span class="priority-dot dot-medium"></span>
                                <span>Medium</span>
                            </div>
                        </label>
                        <label class="priority-option">
                            <input type="radio" asp-for="NewTask.Priority" value="high" />
                            <div class="priority-pill">
                                <span class="priority-dot dot-high"></span>
                                <span>High</span>
                            </div>
                        </label>
                    </div>
                    <span asp-validation-for="NewTask.Priority" class="field-error"></span>
                </div>

                <!-- Description -->
                <div class="field-group">
                    <label class="field-label" for="description">TASK DESCRIPTION <span class="required-star">*</span></label>
                    <textarea class="pill-input" id="description" asp-for="NewTask.Description" rows="4"
                              placeholder="Describe the task scope, objectives, and any specific requirements..."></textarea>
                    <span asp-validation-for="NewTask.Description" class="field-error"></span>
                </div>

            </form>
        </div>

        <!-- Footer -->
        <div class="modal-footer">
            <button type="button" class="btn-cancel" data-close-modal>Cancel</button>
            <button class="btn-create" id="createBtn" type="submit" form="taskForm">
                <span class="material-symbols-outlined"
                      style="font-variation-settings:'FILL' 1; font-size:20px;">add</span>
                Create Task
            </button>
        </div>

    </div>
</div>

@section Scripts {
    <script src="~/js/tasks-index.js" asp-append-version="true"></script>
    <script src="~/js/tasks-create.js" asp-append-version="true"></script>
}
