@model DTIOneLink.Models.OtpViewModel
@{
    Layout = null;
    ViewData["Title"] = "Verify Code - DTI Laguna Provincial Office";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Anton&display=swap" rel="stylesheet">
    <link href="https://api.fontshare.com/v2/css?f[]=open-sauce-sans@400,500,600,700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body>

    <main class="login-page">
        <div class="canvas">

            <div class="bar bar-top"></div>
            <div class="bar bar-bottom"></div>

            <div class="logo">
                <img src="~/images/dti-logo.png" alt="DTI Laguna Provincial Office logo" />
            </div>

            <section class="login-card" aria-label="Verify code form">
                <h1 class="login-title"><span class="navy">Ver</span><span class="accent">ify</span></h1>

                <p class="login-subtitle">
                    We sent a 6-digit code to <strong>@Model.MaskedEmail</strong>.
                    Enter it below to continue.
                </p>

                @if (TempData["OtpMessage"] != null)
                {
                    <div class="form-summary-error" role="status" style="background:#eaf5ea;color:#1b5e20;border-color:#1b5e20;">
                        @TempData["OtpMessage"]
                    </div>
                }

                <form asp-controller="Account" asp-action="VerifyOtp" method="post" novalidate>
                    @Html.AntiForgeryToken()

                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty] != null)
                    {
                        <div class="form-summary-error" role="alert">
                            @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })
                        </div>
                    }

                    <div class="field-group">
                        <label asp-for="Code">Verification Code</label>
                        <div class="input-wrapper">
                            <input asp-for="Code" class="text-input" inputmode="numeric" autocomplete="one-time-code"
                                   maxlength="6" placeholder="000000" autofocus />
                        </div>
                        <span asp-validation-for="Code" class="field-error"></span>
                    </div>

                    <button type="submit" class="btn-login">VERIFY</button>
                </form>

                <form asp-controller="Account" asp-action="ResendOtp" method="post" class="resend-form">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="forgot-link" style="background:none;border:none;cursor:pointer;padding:0;">
                        Didn't get a code? Resend
                    </button>
                </form>
            </section>

        </div>
    </main>

</body>
</html>
