@model DTIOneLink.Models.ChangePasswordViewModel
@{
    Layout = null;
    ViewData["Title"] = "Change Password - DTI Laguna Provincial Office";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Anton&display=swap" rel="stylesheet">
    <link href="https://api.fontshare.com/v2/css?f[]=open-sauce-sans@400,500,600,700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body>

    <main class="login-page">
        <div class="canvas">

            <div class="bar bar-top"></div>
            <div class="bar bar-bottom"></div>

            <div class="logo">
                <img src="~/images/dti-logo.png" alt="DTI Laguna Provincial Office logo" />
            </div>

            <section class="login-card" aria-label="Change password form">
                <h1 class="login-title"><span class="navy">New</span> <span class="accent">Password</span></h1>

                <p class="login-subtitle">
                    Your account is still using the default password. Set a new password to continue.
                </p>

                <form asp-controller="Account" asp-action="ChangePassword" method="post" novalidate>
                    @Html.AntiForgeryToken()

                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty] != null)
                    {
                        <div class="form-summary-error" role="alert">
                            @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })
                        </div>
                    }

                    <div class="field-group">
                        <label asp-for="NewPassword">New Password</label>
                        <div class="input-wrapper">
                            <input asp-for="NewPassword" class="text-input" autocomplete="new-password"
                                   placeholder="At least 8 characters" />
                        </div>
                        <span asp-validation-for="NewPassword" class="field-error"></span>
                    </div>

                    <div class="field-group">
                        <label asp-for="ConfirmPassword">Confirm Password</label>
                        <div class="input-wrapper">
                            <input asp-for="ConfirmPassword" class="text-input" autocomplete="new-password"
                                   placeholder="Re-enter new password" />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="field-error"></span>
                    </div>

                    <button type="submit" class="btn-login">SAVE PASSWORD</button>
                </form>
            </section>

        </div>
    </main>

</body>
</html>
