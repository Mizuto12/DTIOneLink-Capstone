@model DTIOneLink.Models.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Login - DTI Laguna Provincial Office";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <!-- Anton (Login heading) + Open Sauce Sans (labels / inputs / button) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Anton&display=swap" rel="stylesheet">
    <link href="https://api.fontshare.com/v2/css?f[]=open-sauce-sans@400,500,600,700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body>

    <main class="login-page">
        <div class="canvas">

            <!-- Decorative full-width navy bars -->
            <div class="bar bar-top"></div>
            <div class="bar bar-bottom"></div>

            <div class="logo">
                <img src="~/images/dti-logo.png" alt="DTI Laguna Provincial Office logo" />
            </div>

            <!-- Right: Login card -->
            <section class="login-card" aria-label="Login form">
                <h1 class="login-title"><span class="navy">Log</span><span class="accent">in</span></h1>

                <form asp-controller="Account" asp-action="Login" method="post" novalidate id="loginForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ReturnUrl" />

                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty] != null)
                    {
                        <div class="form-summary-error" role="alert">
                            @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })
                        </div>
                    }

                    <div class="field-group">
                        <label asp-for="Username">Email</label>
                        <div class="input-wrapper">
                            <span class="input-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="3.2"></circle><path d="M5 19c0-3.5 3.1-6 7-6s7 2.5 7 6"></path></svg>
                            </span>
                            <input asp-for="Username" class="text-input has-icon-left" autocomplete="username" placeholder="Enter your Email" />
                        </div>
                        <span asp-validation-for="Username" class="field-error"></span>
                    </div>

                    <div class="field-group">
                        <label asp-for="Password">Password</label>
                        <div class="input-wrapper">
                            <input asp-for="Password" class="text-input has-icon-right" autocomplete="current-password" placeholder="•••••••••••" />
                            <button type="button" class="toggle-password" id="togglePassword" aria-label="Show password">
                                <svg class="icon-eye" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                                <svg class="icon-eye-off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3l18 18"></path><path d="M10.6 5.2A10.6 10.6 0 0 1 12 5c6.5 0 10 7 10 7a15.5 15.5 0 0 1-3.1 4.1M6.5 6.6A15.7 15.7 0 0 0 2 12s3.5 7 10 7c1.1 0 2.1-.2 3-.5"></path><path d="M9.5 9.6A3 3 0 0 0 12 15a3 3 0 0 0 2.4-1.2"></path></svg>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="field-error"></span>
                        <a href="#" class="forgot-link" id="forgotPasswordLink">Forgot Password?</a>
                    </div>

                    <button type="submit" class="btn-login">LOGIN</button>
                </form>
            </section>

        </div>
    </main>

    <script src="~/js/login.js" asp-append-version="true"></script>
</body>
</html>
